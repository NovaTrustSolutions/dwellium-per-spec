# Agenteryx / Holocron editor local database.
# Copy this file to `.env` for local development.

HOLOCRON_DB_URI=postgresql://postgres:postgres@localhost:5432/holocron_rag

# Optional: Honcho's own backing database, used only by `npm run db:setup`
# to check whether the Honcho schema is reachable.
# DB_CONNECTION_URI=postgresql://postgres:postgres@localhost:5432/postgres
