# qualia-shell environment example
# Copy to .env and populate locally. Never commit .env.

# ─── AppFolio parity (Phase 0-5) ───
# Controls whether the AppFolio-derived fixture seeds (real captured data)
# are surfaced in the app. Per GR-7 of AppFolio_Parity_Implementation_Plan.md,
# this must be `false` for any external/customer-demo build to avoid leaking
# real tenant/vendor PII. Default for dev/staging is `true` (Phase 4 shipped 2026-04-30).
VITE_APPFOLIO_SEEDS=true

# ─── Phase 5 backend parity ───
# Reserved for Phase-5 Task 5.3-5.5 E2E + 5.7 a11y validation flips; not
# currently consumed at runtime. Defined at Task 5.1c (API version bump)
# alongside the X-Qualia-API: v2 header introduction in strataApi.backend.ts.
# Future Phase-5 tasks will read this flag to toggle live-backend wiring
# during E2E + a11y validation runs.
VITE_PARITY_LIVE_BACKEND=false

# ─── Existing ───
# (sensitive values — do not commit real .env; placeholder only)
VITE_API_BASE_URL=http://localhost:3000
