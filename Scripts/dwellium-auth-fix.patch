+        await act(async () => {
+            window.dispatchEvent(new Event('focus'));
+        });
+
+        await waitFor(() => expect(result.current.sessionExpired).toBe(true));
+        expect(result.current.isAuthenticated).toBe(true); // shell preserved
+    });
 });
