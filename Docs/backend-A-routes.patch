diff --git a/ai-dashboard369-file-manager/src/routes/tenantAdminRoutes.ts b/ai-dashboard369-file-manager/src/routes/tenantAdminRoutes.ts
new file mode 100644
index 0000000..c640ead
--- /dev/null
+++ b/ai-dashboard369-file-manager/src/routes/tenantAdminRoutes.ts
@@ -0,0 +1,199 @@
+/**
+ * Tenant-portal admin routes — mounted at /api/dwellium/tenant/admin.
+ *
+ * Mirrors the strataApi.static.ts shape so the management-side
+ * TenantPortalModule renders against real backend data the same way
+ * it renders in static mode.
+ *
+ * Added during Milestone-1 of the Dwellium 24h functionality bring-up
+ * (sibling-repo dwellium-per-spec branch feat/functionality-bringup).
+ * Routes resolve 404s previously surfaced at Check-in 1.
+ */
+
+import { Router, Request, Response } from 'express';
+import { database as db } from '../services/database';
+
+const router = Router();
+
+interface UnitRow {
+    id: string;
+    property_id: string;
+    unit_number: string;
+    rent_amount: number | null;
+    status: string;
+    current_tenant_id: string | null;
+    lease_start: string | null;
+    lease_end: string | null;
+}
+
+interface EntityRow {
+    id: string;
+    entity_type: string;
+    name: string;
+    email: string | null;
+    phone: string | null;
+    metadata: string;
+    status: string;
+}
+
+interface WorkitemRow {
+    id: string;
+    type: string;
+    domain: string;
+    status: string;
+    title: string;
+    priority: string;
+    unit_id: string | null;
+    assigned_to: string | null;
+    created_at: string;
+}
+
+const NINETY_DAYS_MS = 90 * 86_400_000;
+
+router.get('/stats', (_req: Request, res: Response) => {
+    const tenants = db
+        .prepare(`SELECT id FROM entity_profiles WHERE entity_type = 'tenant' AND status = 'active'`)
+        .all() as Array<{ id: string }>;
+    const units = db
+        .prepare(`SELECT status, lease_end FROM units`)
+        .all() as Array<{ status: string; lease_end: string | null }>;
+    const openMaint = db
+        .prepare(`SELECT COUNT(*) AS n FROM workitems
+                  WHERE type = 'work_order' AND domain = 'maintenance'
+                  AND status IN ('open', 'in_progress')`)
+        .get() as { n: number };
+    const now = Date.now();
+    const expiringLeases = units.filter(u => {
+        if (!u.lease_end) return false;
+        const t = new Date(u.lease_end).getTime();
+        return Number.isFinite(t) && t > now && (t - now) <= NINETY_DAYS_MS;
+    }).length;
+    res.json({
+        totalTenants: tenants.length,
+        totalUnits: units.length,
+        occupiedUnits: units.filter(u => u.status === 'occupied').length,
+        vacantUnits: units.filter(u => u.status === 'vacant').length,
+        openMaintenanceRequests: openMaint.n,
+        expiringLeases,
+    });
+});
+
+router.get('/directory', (req: Request, res: Response) => {
+    const tenants = db
+        .prepare(`SELECT id, entity_type, name, email, phone, metadata, status
+                  FROM entity_profiles
+                  WHERE entity_type = 'tenant' AND status = 'active'`)
+        .all() as EntityRow[];
+    const units = db
+        .prepare(`SELECT id, property_id, unit_number, rent_amount, status,
+                         current_tenant_id, lease_start, lease_end FROM units`)
+        .all() as UnitRow[];
+    const unitByTenantName = new Map<string, UnitRow>();
+    for (const u of units) {
+        if (u.current_tenant_id) unitByTenantName.set(String(u.current_tenant_id), u);
+    }
+    const now = Date.now();
+    const rows = tenants.map(t => {
+        const meta = safeJson(t.metadata) || {};
+        const u = unitByTenantName.get(t.name) || null;
+        const leaseEnd = u?.lease_end ?? null;
+        let leaseRemainingDays: number | null = null;
+        if (leaseEnd) {
+            const ts = new Date(leaseEnd).getTime();
+            if (Number.isFinite(ts)) {
+                leaseRemainingDays = Math.max(0, Math.round((ts - now) / 86_400_000));
+            }
+        }
+        const emailRaw = typeof t.email === 'string' ? t.email.split(',')[0].trim() : '';
+        return {
+            id: t.id,
+            name: t.name,
+            email: emailRaw,
+            phone: t.phone || null,
+            unitNumber: u?.unit_number || meta.unit || null,
+            propertyName: meta.propertyName || null,
+            rentAmount: u?.rent_amount ?? null,
+            leaseStart: u?.lease_start ?? null,
+            leaseEnd,
+            leaseRemainingDays,
+            status: t.status,
+        };
+    });
+    res.json(filterBySearch(rows, req.query.search, ['name', 'unitNumber', 'propertyName']));
+});
+
+router.get('/maintenance', (req: Request, res: Response) => {
+    const wos = db
+        .prepare(`SELECT id, type, domain, status, title, priority, unit_id, assigned_to, created_at
+                  FROM workitems WHERE type = 'work_order' AND domain = 'maintenance'`)
+        .all() as WorkitemRow[];
+    const units = db
+        .prepare(`SELECT id, unit_number, current_tenant_id FROM units`)
+        .all() as Array<{ id: string; unit_number: string; current_tenant_id: string | null }>;
+    const unitById = new Map<string, { unit_number: string; current_tenant_id: string | null }>();
+    for (const u of units) unitById.set(u.id, u);
+    const rows = wos.map(w => {
+        const u = w.unit_id ? unitById.get(w.unit_id) : null;
+        return {
+            id: w.id,
+            title: w.title || '',
+            tenantName: u?.current_tenant_id ? String(u.current_tenant_id) : '',
+            unitNumber: u?.unit_number || null,
+            priority: w.priority || 'medium',
+            status: w.status || 'open',
+            createdAt: w.created_at || '1970-01-01T00:00:00.000Z',
+        };
+    });
+    res.json(filterBySearch(rows, req.query.search, ['title', 'tenantName', 'unitNumber']));
+});
+
+// Payments + messages + lease-alerts have no backend table yet; return [].
+// Milestone-1 marks these as "wired-not-populated" — module renders without
+// errors, and Milestone-2+ can attach a real ledger / inbox source.
+router.get('/payments', (_req: Request, res: Response) => res.json([]));
+router.get('/messages', (_req: Request, res: Response) => res.json([]));
+
+router.get('/lease-alerts', (_req: Request, res: Response) => {
+    const units = db
+        .prepare(`SELECT id, unit_number, lease_end, current_tenant_id FROM units WHERE lease_end IS NOT NULL`)
+        .all() as Array<{ id: string; unit_number: string; lease_end: string; current_tenant_id: string | null }>;
+    const now = Date.now();
+    const alerts = units
+        .map(u => {
+            const ts = new Date(u.lease_end).getTime();
+            if (!Number.isFinite(ts)) return null;
+            const remainingMs = ts - now;
+            if (remainingMs < 0 || remainingMs > NINETY_DAYS_MS) return null;
+            return {
+                unitId: u.id,
+                unitNumber: u.unit_number,
+                tenantName: u.current_tenant_id ? String(u.current_tenant_id) : null,
+                leaseEnd: u.lease_end,
+                daysRemaining: Math.max(0, Math.round(remainingMs / 86_400_000)),
+            };
+        })
+        .filter(Boolean);
+    res.json(alerts);
+});
+
+function filterBySearch<T extends Record<string, unknown>>(
+    rows: T[],
+    search: unknown,
+    fields: (keyof T)[],
+): T[] {
+    if (typeof search !== 'string' || search.length === 0) return rows;
+    const q = search.toLowerCase();
+    return rows.filter(r =>
+        fields.some(f => {
+            const v = r[f];
+            return typeof v === 'string' && v.toLowerCase().includes(q);
+        })
+    );
+}
+
+function safeJson(s: string | null): Record<string, any> | null {
+    if (!s) return null;
+    try { return JSON.parse(s); } catch { return null; }
+}
+
+export default router;
