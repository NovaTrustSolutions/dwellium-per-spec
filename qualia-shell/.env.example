# qualia-shell environment example
# Copy to .env and populate locally. Never commit .env.

# ─── AppFolio parity (Phase 0-5) ───
# Controls whether the AppFolio-derived fixture seeds (real captured data)
# are surfaced in the app. Per GR-7 of AppFolio_Parity_Implementation_Plan.md,
# this must be `false` for any external/customer-demo build to avoid leaking
# real tenant/vendor PII. Default for dev/staging is `true` (Phase 4 shipped 2026-04-30).
VITE_APPFOLIO_SEEDS=true

# ─── Phase 5 backend parity ───
# Reserved for Phase-5 Task 5.3-5.5 E2E + 5.7 a11y validation flips; not
# currently consumed at runtime. Defined at Task 5.1c (API version bump)
# alongside the X-Qualia-API: v2 header introduction in strataApi.backend.ts.
# Future Phase-5 tasks will read this flag to toggle live-backend wiring
# during E2E + a11y validation runs.
VITE_PARITY_LIVE_BACKEND=false

# ─── Phase 5 Task 5.3 — Playwright E2E target ───
# Selects which Playwright project runs and which webServer composition
# starts. Consumed by qualia-shell/playwright.config.ts at config-load time.
#   unset / "static" (default) → chromium project; Vite only
#                                (VITE_USE_STATIC_API=true)
#   "real-backend"             → real-backend project; sibling Express on
#                                :3000 + Vite (VITE_USE_STATIC_API=false).
#                                Requires ../ai-dashboard369-file-manager
#                                + Phase-4-bulk-data-seeded staging DB
#                                (out-of-repo per R-4 v2.26 cross-repo
#                                amendment + Phase_5_Plan.md L142-159).
# Defined-but-not-required convention mirrors VITE_PARITY_LIVE_BACKEND.
E2E_TARGET=

# ─── Existing ───
# (sensitive values — do not commit real .env; placeholder only)
VITE_API_BASE_URL=http://localhost:3000

# ─── Google account login ───
# Web OAuth client ID. Configure the same value as GOOGLE_CLIENT_ID on the backend.
VITE_GOOGLE_CLIENT_ID=
# Password/quick-user login is hidden by default; enable only for local development.
VITE_DEV_LOGIN=false

# ─── Account persistence ───
# Syncs account-scoped artifacts, files UI state, workspace UI, workspaces, and
# encrypted integration secrets through the backend /api/objects One Save spine.
VITE_ONE_SAVE=true
